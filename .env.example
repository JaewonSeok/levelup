# PostgreSQL 연결 문자열 (Supabase Pooler — 일반 쿼리용)
DATABASE_URL="postgresql://USER:PASSWORD@pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# PostgreSQL 직접 연결 (마이그레이션/prisma db push 전용)
DIRECT_URL="postgresql://USER:PASSWORD@db.PROJECT.supabase.co:5432/postgres?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # openssl rand -base64 32

# Google OAuth (Google Cloud Console → API 및 서비스 → 사용자 인증 정보)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic API (AI 리포트 기능 — 미설정 시 AI 리포트 비활성화)
ANTHROPIC_API_KEY=""    # Anthropic Console에서 발급 (sk-ant-api03-...)

# SMTP (이메일 발송 — 미설정 시 발송 생략)
SMTP_HOST=""            # 예: smtp.gmail.com
SMTP_PORT="587"
SMTP_SECURE="false"     # 465 포트면 true
SMTP_USER=""            # SMTP 계정 이메일
SMTP_PASS=""            # SMTP 비밀번호 또는 앱 비밀번호
SMTP_FROM=""            # 발신자 표시명 (선택)

# IP 접근 제한 (쉼표로 구분된 허용 IP 목록 — 미설정 시 기본값 사용)
ALLOWED_IPS=            # 예: 220.85.141.12,220.85.141.27
